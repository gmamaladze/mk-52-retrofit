[Unit]
Description=МК-52 web UI (browser access, runs alongside the physical controller)
After=local-fs.target network-online.target
Wants=network-online.target

[Service]
# tools/install-pi.sh auto-detects and rewrites these.
ExecStart=/usr/bin/python3 -u webui/server.py 8080 0.0.0.0
WorkingDirectory=/home/pi/mk-52-retrofit

Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

User=pi

[Install]
WantedBy=multi-user.target
